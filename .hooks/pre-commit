#!/usr/bin/env bash
# .hooks/pre-commit
# Injects "## Author\n\n<author from branch name>" into every newly-staged challenge README.md
# A "challenge README" is any README.md that lives at depth >=3:
#   <CTF>/<Category>/<Challenge>/README.md
#
# Expected branch format:
#   <CTF_name>/<author_name>
set -euo pipefail

BRANCH_NAME=$(git branch --show-current 2>/dev/null || echo "")
AUTHOR=${BRANCH_NAME#*/}

if [[ -z "$BRANCH_NAME" || "$BRANCH_NAME" != */* || -z "$AUTHOR" ]]; then
    echo "pre-commit: WARNING: branch name must follow '<CTF_name>/<author_name>', skipping author injection."
    exit 0
fi

# Collect all updated (status M) README.md files from the index
mapfile -t NEW_READMES < <(
    git diff --cached --name-only --diff-filter=M \
    | grep -E '^[^/]+/[^/]+/[^/]+/README\.md$' \
    || true
)

if [[ ${#NEW_READMES[@]} -eq 0 ]]; then
    exit 0
fi

for readme in "${NEW_READMES[@]}"; do
    # Skip if the file no longer exists on disk (e.g. deleted after staging)
    [[ -f "$readme" ]] || continue

    # Skip if an Author section already exists
    if grep -q "^## Author" "$readme"; then
        continue
    fi

    printf '\n## Author\n\n%s\n' "$AUTHOR" >> "$readme"

    # Re-stage the modified file so the author line is part of the commit
    git add "$readme"

    echo "pre-commit: added author '$AUTHOR' to $readme"
done

exit 0
